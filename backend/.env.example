# Copie este arquivo para ".env" (o .env real nunca vai pro git).
# Credenciais batem com o docker-compose.yml da raiz do projeto.
# Porta 5433 (não 5432): evita conflito com um Postgres nativo que já pode
# estar instalado na sua máquina, ocupando a porta padrão.
DATABASE_URL="postgresql://analitica:analitica@localhost:5433/fleet_test?schema=telemetria"
